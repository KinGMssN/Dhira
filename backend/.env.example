# ── DHIRA BACKEND — ENVIRONMENT VARIABLES ──────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Clusters → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/dhira?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ───────────────────────────────────────────────────────────────────
# Your frontend domain(s). Comma-separated. No trailing slash.
# Example: https://dhira.in,https://www.dhira.in
# For local dev also add: http://127.0.0.1:5500,http://localhost:5500
ALLOWED_ORIGINS=https://YOUR_GITHUB_USERNAME.github.io,http://127.0.0.1:5500,http://localhost:5500

# ── First-run Admin ────────────────────────────────────────────────────────
# Used ONLY by the seed script (npm run seed-admin).
# After seeding, change your password through the admin panel.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dhira2024
